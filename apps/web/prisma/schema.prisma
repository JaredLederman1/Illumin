generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                            String               @id @default(cuid())
  email                         String               @unique
  createdAt                     DateTime             @default(now()) @map("created_at")
  notificationEmailMode         String               @default("digest_daily") @map("notification_email_mode")
  notificationEmailLastSentAt   DateTime?            @map("notification_email_last_sent_at")
  notificationUnsubscribeToken  String?              @unique @map("notification_unsubscribe_token")
  accounts                      Account[]
  snapshots                     NetWorthSnapshot[]
  onboardingProfile             OnboardingProfile?
  employmentBenefits            EmploymentBenefits?
  budget                        Budget?
  categoryRules                 CategoryRule[]
  merchantRenameRules           MerchantRenameRule[]
  financialActions              FinancialAction[]
  checklistItems                ChecklistItem[]
  recurringExclusions           RecurringExclusion[]
  budgetRollovers               BudgetRollover[]
  analyticsHoldings             AnalyticsHolding[]
  recoveryEvents                RecoveryEvent[]
  scans                         Scan[]
  signals                       Signal[]
  signalStates                  SignalState[]
  signalSnapshots               SignalSnapshot[]
  notifications                 Notification[]
}

model FinancialAction {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  label       String
  description String?
  priority    Int      @default(0)
  category    String   @default("general")
  done        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("financial_actions")
}

model Budget {
  id            String   @id @default(cuid())
  userId        String   @unique @map("user_id")
  strategy      String
  monthlyIncome Float    @map("monthly_income")
  categories    Json
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id])

  @@map("budgets")
}

model Account {
  id                  String             @id @default(cuid())
  userId              String             @map("user_id")
  institutionName     String             @map("institution_name")
  accountType         String             @map("account_type")
  balance             Float              @default(0)
  last4               String?
  classification      String             @default("asset")
  apr                 Float?
  customLabel         String?            @map("custom_label")
  aprConfirmedAt      DateTime?          @map("apr_confirmed_at")
  plaidAccountId      String?            @unique @map("plaid_account_id")
  plaidAccessToken    String?            @map("plaid_access_token")
  plaidItemId         String?            @map("plaid_item_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  lastSyncedAt        DateTime?          @map("last_synced_at")
  lastSyncAttemptedAt DateTime?          @map("last_sync_attempted_at")
  lastSyncError       String?            @map("last_sync_error")
  user                User               @relation(fields: [userId], references: [id])
  transactions        Transaction[]
  holdings            Holding[]
  analyticsHoldings   AnalyticsHolding[]

  @@index([lastSyncedAt])
  @@map("accounts")
}

model Security {
  id              String    @id @default(cuid())
  plaidSecurityId String?   @unique @map("plaid_security_id")
  ticker          String?
  name            String
  type            String
  closePrice      Float?    @map("close_price")
  closePriceAt    DateTime? @map("close_price_at")
  isoCode         String?   @map("iso_code")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  holdings        Holding[]

  @@map("securities")
}

model Holding {
  id         String   @id @default(cuid())
  accountId  String   @map("account_id")
  securityId String   @map("security_id")
  quantity   Float
  costBasis  Float?   @map("cost_basis")
  value      Float
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  security   Security @relation(fields: [securityId], references: [id])

  @@unique([accountId, securityId])
  @@map("holdings")
}

model AnalyticsHolding {
  id           String   @id @default(cuid())
  accountId    String   @map("account_id")
  userId       String   @map("user_id")
  ticker       String
  name         String
  assetClass   String   @map("asset_class")
  sector       String?
  geography    String?
  quantity     Float
  costBasis    Float?   @map("cost_basis")
  currentPrice Float    @map("current_price")
  currentValue Float    @map("current_value")
  beta         Float?
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  account      Account  @relation(fields: [accountId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([accountId, ticker])
  @@map("analytics_holdings")
}

model Transaction {
  id           String    @id @default(cuid())
  accountId    String    @map("account_id")
  merchantName String?   @map("merchant_name")
  amount       Float
  category     String?
  date         DateTime
  pending      Boolean   @default(false)
  tags         String[]  @default([])
  lastSyncedAt DateTime? @map("last_synced_at")
  account      Account   @relation(fields: [accountId], references: [id])

  @@map("transactions")
}

model NetWorthSnapshot {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  totalAssets      Float    @map("total_assets")
  totalLiabilities Float    @map("total_liabilities")
  recordedAt       DateTime @default(now()) @map("recorded_at")
  user             User     @relation(fields: [userId], references: [id])

  @@map("net_worth_snapshots")
}

model OnboardingProfile {
  id                        String    @id @default(cuid())
  userId                    String    @unique @map("user_id")
  age                       Int
  annualIncome              Float     @map("annual_income")
  savingsRate               Float     @map("savings_rate")
  retirementAge             Int       @map("retirement_age")
  locationCity              String?   @map("location_city")
  locationState             String?   @map("location_state")
  jobTitle                  String?   @map("job_title")
  employer                  String?
  employerStartDate         DateTime? @map("employer_start_date")
  targetRetirementIncome    Float?    @map("target_retirement_income")
  emergencyFundMonthsTarget Int?      @default(6) @map("emergency_fund_months_target")
  riskTolerance             Int?      @map("risk_tolerance")
  contractParsedData        Json?     @map("contract_parsed_data")
  contractUploadedAt        DateTime? @map("contract_uploaded_at")
  contractStepSkippedAt     DateTime? @map("contract_step_skipped_at")
  introSeenAt               DateTime? @map("intro_seen_at")
  completedAt               DateTime? @map("completed_at")
  careerLevel               String?        @map("career_level")
  careerTargetLevel         String?        @map("career_target_level")
  industry                  String?
  filingStatus              FilingStatus?  @map("filing_status")
  dependents                Int?
  employer401kMatchPct      Float?         @map("employer_401k_match_pct")
  vestingStatus             VestingStatus? @map("vesting_status")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")
  user                      User      @relation(fields: [userId], references: [id])

  @@map("onboarding_profiles")
}

enum FilingStatus {
  SINGLE
  MARRIED_FILING_JOINTLY
  MARRIED_FILING_SEPARATELY
  HEAD_OF_HOUSEHOLD
  QUALIFYING_SURVIVING_SPOUSE
}

enum VestingStatus {
  NOT_VESTED
  PARTIALLY_VESTED
  FULLY_VESTED
  CLIFF_NOT_REACHED
}

model CategoryRule {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  merchantName String   @map("merchant_name")
  category     String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, merchantName])
  @@map("category_rules")
}

model MerchantRenameRule {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  originalName String   @map("original_name")
  renamedTo    String   @map("renamed_to")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, originalName])
  @@map("merchant_rename_rules")
}

model ChecklistItem {
  id        String   @id @default(cuid())
  userId    String
  text      String
  completed Boolean  @default(false)
  source    String   @default("ai_coach")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecurringExclusion {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  merchantName String   @map("merchant_name")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantName])
  @@map("recurring_exclusions")
}

model BudgetRollover {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  categoryName String   @map("category_name")
  periodYear   Int      @map("period_year")
  periodMonth  Int      @map("period_month")
  budgeted     Float
  spent        Float
  rollover     Float
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, categoryName, periodYear, periodMonth])
  @@map("budget_rollovers")
}

model EmploymentBenefits {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  extractedAt          DateTime @default(now()) @map("extracted_at")
  rawExtraction        Json     @map("raw_extraction")
  has401k              Boolean  @default(false) @map("has_401k")
  matchRate            Float?   @map("match_rate")
  matchCap             Float?   @map("match_cap")
  vestingYears         Int?     @map("vesting_years")
  hasHSA               Boolean  @default(false) @map("has_hsa")
  hsaEmployerContrib   Float?   @map("hsa_employer_contrib")
  hasFSA               Boolean  @default(false) @map("has_fsa")
  fsaLimit             Float?   @map("fsa_limit")
  hasRSUs              Boolean  @default(false) @map("has_rsus")
  rsuGrantValue        Float?   @map("rsu_grant_value")
  stockOptionShares    Float?   @map("stock_option_shares")
  paidSickLeaveDays    Int?     @map("paid_sick_leave_days")
  hasESPP              Boolean  @default(false) @map("has_espp")
  esppDiscount         Float?   @map("espp_discount")
  hasCommuterBenefits  Boolean  @default(false) @map("has_commuter_benefits")
  commuterMonthlyLimit Float?   @map("commuter_monthly_limit")
  tuitionReimbursement Float?   @map("tuition_reimbursement")
  wellnessStipend      Float?   @map("wellness_stipend")
  totalAnnualValue     Float?   @map("total_annual_value")
  capturedAnnualValue  Float?   @map("captured_annual_value")
  actionItemsDone      Json     @default("[]") @map("action_items_done")
  user                 User     @relation(fields: [userId], references: [id])

  @@map("employment_benefits")
}

model InviteCode {
  id         String    @id @default(cuid())
  code       String    @unique
  maxUses    Int       @default(1) @map("max_uses")
  usedCount  Int       @default(0) @map("used_count")
  expiresAt  DateTime? @map("expires_at")
  note       String?
  createdBy  String?   @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  disabledAt DateTime? @map("disabled_at")

  redemptions InviteCodeRedemption[]

  @@map("invite_codes")
}

model InviteCodeRedemption {
  id           String   @id @default(cuid())
  inviteCodeId String   @map("invite_code_id")
  userId       String   @map("user_id")
  redeemedAt   DateTime @default(now()) @map("redeemed_at")

  inviteCode InviteCode @relation(fields: [inviteCodeId], references: [id], onDelete: Cascade)

  @@unique([inviteCodeId, userId])
  @@index([userId])
  @@map("invite_code_redemptions")
}

model RecoveryEvent {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  gapId       String   @map("gap_id")
  domain      String
  annualValue Float    @map("annual_value")
  recoveredAt DateTime @default(now()) @map("recovered_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gapId])
  @@index([userId])
  @@map("recovery_events")
}

model Scan {
  id              String           @id @default(cuid())
  userId          String           @map("user_id")
  startedAt       DateTime         @default(now()) @map("started_at")
  completedAt     DateTime?        @map("completed_at")
  status          String           @default("running")
  trigger         String
  signalsChecked  Int              @default(0) @map("signals_checked")
  signalsFlagged  Int              @default(0) @map("signals_flagged")
  signalsResolved Int              @default(0) @map("signals_resolved")
  errorMessage    String?          @map("error_message")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots       SignalSnapshot[]

  @@index([userId, startedAt(sort: Desc)])
  @@index([status])
  @@map("scans")
}

model Signal {
  id                    String    @id @default(cuid())
  userId                String    @map("user_id")
  gapId                 String    @map("gap_id")
  domain                String
  state                 String    @default("new")
  severity              String    @default("advisory")
  annualValue           Float     @map("annual_value")
  lifetimeValue         Float?    @map("lifetime_value")
  payload               Json?
  firstDetectedAt       DateTime  @default(now()) @map("first_detected_at")
  lastSeenAt            DateTime  @default(now()) @map("last_seen_at")
  acknowledgedAt        DateTime? @map("acknowledged_at")
  actedAt               DateTime? @map("acted_at")
  resolvedAt            DateTime? @map("resolved_at")
  firstDetectedInScanId String?   @map("first_detected_in_scan_id")
  lastUpdatedInScanId   String?   @map("last_updated_in_scan_id")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications         Notification[]

  @@unique([userId, gapId])
  @@index([userId, state])
  @@index([userId, lastSeenAt(sort: Desc)])
  @@index([domain])
  @@map("signals")
}

model SignalState {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  gapId         String   @map("gap_id")
  currentState  String   @map("current_state")
  stateSince    DateTime @default(now()) @map("state_since")
  previousState String?  @map("previous_state")
  lastCheckedAt DateTime @default(now()) @map("last_checked_at")
  lastValue     Float?   @map("last_value")
  previousValue Float?   @map("previous_value")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gapId])
  @@index([userId, currentState])
  @@map("signal_states")
}

model SignalSnapshot {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  gapId         String   @map("gap_id")
  scanId        String   @map("scan_id")
  domain        String
  annualValue   Float    @map("annual_value")
  lifetimeValue Float?   @map("lifetime_value")
  severity      String
  state         String
  payload       Json?
  capturedAt    DateTime @default(now()) @map("captured_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scan          Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([userId, gapId, capturedAt(sort: Desc)])
  @@index([scanId])
  @@index([userId, capturedAt(sort: Desc)])
  @@map("signal_snapshots")
}

model Notification {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  signalId     String    @map("signal_id")
  kind         String
  domain       String
  dollarImpact Float?    @map("dollar_impact")
  title        String
  body         String?
  readAt       DateTime? @map("read_at")
  dismissedAt  DateTime? @map("dismissed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal       Signal    @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
  @@index([signalId])
  @@map("notifications")
}
