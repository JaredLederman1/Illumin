{
  "buildCommand": "cd apps/web && npx prisma generate && npx next build",
  "outputDirectory": "apps/web/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/scan-all",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/email-digest",
      "schedule": "0 14 * * *"
    }
  ]
}
